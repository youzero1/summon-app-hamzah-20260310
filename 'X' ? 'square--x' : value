'use client';

import React from 'react';
import { GameStatus as GameStatusType, Player } from '@/lib/gameLogic';

interface GameStatusProps {
  status: GameStatusType;
  currentPlayer: Player;
}

const GameStatus: React.FC<GameStatusProps> = ({ status, currentPlayer }) => {
  let message: string;
  let className = 'game-status';

  switch (status) {
    case 'x_wins':
      message = '🎉 X Wins!';
      className += ' game-status--x-wins';
      break;
    case 'o_wins':
      message = '🎉 O Wins!';
      className += ' game-status--o-wins';
      break;
    case 'draw':
      message = "🤝 It's a Draw!";
      className += ' game-status--draw';
      break;
    case 'in_progress':
    default:
      message = `${currentPlayer}'s Turn`;
      className += currentPlayer === 'X' ? ' game-status--x-turn' : ' game-status--o-turn';
      break;
  }

  return <div className={className}>{message}</div>;
};

export default GameStatus;
