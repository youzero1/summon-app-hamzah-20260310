'O' ? 'square--o' : '',
    isWinning ? 'square--winning' : '',
    disabled || value !== null ? 'square--disabled' : '',
  ]
    .filter(Boolean)
    .join(' ');

  return (
    <button
      className={classNames}
      onClick={onClick}
      disabled={disabled && value === null}
      aria-label={value ? `Cell: ${value}` : 'Empty cell'}
    >
      {value}
    </button>
  );
};

