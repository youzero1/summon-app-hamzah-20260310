import Database from 'better-sqlite3';
import path from 'path';

export interface GameRow {
  id: number;
  board: string;
  status: string;
  current_player: string;
  created_at: string;
  updated_at: string;
}

const dbPath = process.env.DATABASE_PATH
  ? path.resolve(process.cwd(), process.env.DATABASE_PATH)
  : path.resolve(process.cwd(), 'database.sqlite');

let db: Database.Database | null = null;

export function getDatabase(): Database.Database {
  if (db) return db;

  db = new Database(dbPath);
  db.pragma('journal_mode = WAL');

  db.exec(`
    CREATE TABLE IF NOT EXISTS games (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      board TEXT NOT NULL DEFAULT '${JSON.stringify(Array(9).fill(null))}',
      status TEXT NOT NULL DEFAULT 'in_progress',
      current_player TEXT NOT NULL DEFAULT 'X',
      created_at TEXT NOT NULL DEFAULT (datetime('now')),
      updated_at TEXT NOT NULL DEFAULT (datetime('now'))
    )
  `);

  return db;
}

export function createGame(): GameRow {
  const database = getDatabase();
  const board = JSON.stringify(Array(9).fill(null));
  const stmt = database.prepare(
    `INSERT INTO games (board, status, current_player) VALUES (?, ?, ?)`
  );
  const result = stmt.run(board, 'in_progress', 'X');

  const game = database
    .prepare('SELECT * FROM games WHERE id = ?')
    .get(result.lastInsertRowid) as GameRow;

  return game;
}

export function getGame(id: number): GameRow | undefined {
  const database = getDatabase();
  return database.prepare('SELECT * FROM games WHERE id = ?').get(id) as
    | GameRow
    | undefined;
}

export function updateGame(
  id: number,
  board: string,
  status: string,
  currentPlayer: string
): GameRow | undefined {
  const database = getDatabase();
  database
    .prepare(
      `UPDATE games SET board = ?, status = ?, current_player = ?, updated_at = datetime('now') WHERE id = ?`
    )
    .run(board, status, currentPlayer, id);

  return getGame(id);
}

export function getAllGames(): GameRow[] {
  const database = getDatabase();
  return database
    .prepare('SELECT * FROM games ORDER BY updated_at DESC')
    .all() as GameRow[];
}

export function deleteGame(id: number): boolean {
  const database = getDatabase();
  const result = database.prepare('DELETE FROM games WHERE id = ?').run(id);
  return result.changes > 0;
}
