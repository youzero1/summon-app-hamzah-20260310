export function isBoardFull(board: Board): boolean {
  return board.every((cell) => cell !== null);
}

export function getGameStatus(board: Board): GameStatus {
  const winner = checkWinner(board);
  if (winner === 'X') return 'x_wins';
  if (winner === 'O') return 'o_wins';
  if (isBoardFull(board)) return 'draw';
  return 'in_progress';
}

export function getCurrentPlayer(board: Board): Player {
  const xCount = board.filter((c) => c === 'X').length;
  const oCount = board.filter((c) => c === 'O').length;
  return xCount <= oCount ? 'X' : 'O';
}

export function makeMove(board: Board, index: number): Board | null {
  if (index < 0 || index > 8) return null;
  if (board[index] !== null) return null;
  if (checkWinner(board)) return null;
  if (isBoardFull(board)) return null;

  const newBoard = [...board];
  newBoard[index] = getCurrentPlayer(board);
  return newBoard;
}

